---
import Profile from '../components/Profile.svelte';
const { active = 'overview', title = '', subtitle = '' } = Astro.props;

const nav = [
  { key: 'overview', label: "Vue d'ensemble", href: '/' },
  { key: 'portfolio', label: 'Patrimoine', href: '/portefeuille' },
  { key: 'goals', label: 'Objectifs', href: '/objectifs' },
  { key: 'sim', label: 'Simulations', href: '/simulations' },
  { key: 'analysis', label: 'Analyse', href: '/analyse' },
  { key: 'settings', label: 'Paramètres', href: '/parametres' },
];
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} · Horizon</title>
    <meta name="description" content="Horizon — observe et construis ton patrimoine futur." />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <div class="shell">
      <aside class="sidebar">
        <a class="brand" href="/">
          <svg class="brand-mark" viewBox="0 0 20 13" fill="none" aria-hidden="true">
            <path d="M5 10 A5 5 0 0 1 15 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
            <line x1="1.5" y1="10.5" x2="18.5" y2="10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
          </svg>
          <span>Horizon</span>
        </a>
        <nav class="nav">
          {
            nav.map((item) => (
              <a class={`nav-item ${active === item.key ? 'is-active' : ''}`} href={item.href}>
                {item.label}
              </a>
            ))
          }
        </nav>
        <Profile client:only="svelte" />
      </aside>

      <main class="main">
        {
          title && (
            <header class="page-head">
              {subtitle && <p class="eyebrow">{subtitle}</p>}
              <h1>{title}</h1>
            </header>
          )
        }
        <slot />
      </main>
    </div>

    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #050505;
        --card: #0f0f10;
        --card-2: #161618;
        --line: rgba(255, 255, 255, 0.05);
        --line-strong: rgba(255, 255, 255, 0.11);
        --ink: #ffffff;
        --accent: #c9a85d;
        --muted: #8a8a8a;
        --faint: #5c5c5e;
        /* Palette de données désaturée : UI neutre, data colorée (~5 %) */
        --green: #5e9f73;
        --red: #b76b6b;
        --gold: #c9a85d;
        --blue: #4f7cac;
      }
      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; }
      body {
        font-family: 'Inter Tight', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        background: var(--bg); color: var(--ink); min-height: 100vh;
        -webkit-font-smoothing: antialiased; letter-spacing: -0.011em;
      }

      .shell { display: grid; grid-template-columns: 248px 1fr; min-height: 100vh; }
      .sidebar {
        position: sticky; top: 0; height: 100vh; display: flex; flex-direction: column;
        padding: 2rem 1.4rem; gap: .2rem; border-right: 1px solid var(--line);
      }
      .brand { display: inline-flex; align-items: center; gap: .55rem; font-size: 1.25rem; font-weight: 600; letter-spacing: -.02em; color: var(--ink); text-decoration: none; padding: .2rem .6rem; margin-bottom: 2.8rem; }
      .brand-mark { width: 19px; height: 13px; color: var(--ink); flex-shrink: 0; }
      .nav { display: flex; flex-direction: column; gap: .1rem; flex: 1; }
      .nav-item {
        padding: .6rem .65rem; border-radius: 9px; color: var(--muted); text-decoration: none;
        font-weight: 500; font-size: .94rem; transition: color .15s, background .15s;
      }
      .nav-item:hover { color: var(--ink); }
      .nav-item.is-active { color: var(--ink); background: rgba(255,255,255,.05); }

      .main { padding: 3rem 3.5rem 6rem; max-width: 1140px; }
      .page-head { margin-bottom: 2.4rem; }
      .eyebrow { color: var(--muted); margin: 0 0 .6rem; font-size: .85rem; }
      .page-head h1 { font-size: clamp(2.2rem, 4.4vw, 3.2rem); margin: 0; font-weight: 600; letter-spacing: -.035em; }

      @media (max-width: 860px) {
        .shell { grid-template-columns: 1fr; }
        .sidebar { position: static; height: auto; flex-direction: row; align-items: center; flex-wrap: wrap; padding: 1rem 1.2rem; border-right: none; border-bottom: 1px solid var(--line); }
        .brand { margin: 0 1.2rem 0 0; }
        .nav { flex-direction: row; flex: 0; }
        .main { padding: 2rem 1.3rem 4rem; }
      }

      /* ===== Surfaces ===== */
      .panel { background: var(--card); border: 1px solid var(--line); border-radius: 20px; padding: 2rem; }
      .panel-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.5rem; gap: .5rem; }
      .panel-head h2 { font-size: .95rem; margin: 0; font-weight: 600; color: var(--ink); letter-spacing: -.01em; }
      .grid-2 { display: grid; gap: 1.1rem; }

      .field { display: block; margin-bottom: 1.5rem; }
      .field.tight { margin-bottom: 0; }
      .field > span { display: block; font-size: .85rem; color: var(--muted); margin-bottom: .6rem; }
      .field strong { color: var(--ink); font-weight: 600; }

      .input-eur { position: relative; display: flex; align-items: center; }
      .input-eur input {
        width: 100%; background: rgba(255,255,255,.02); border: 1px solid var(--line); color: var(--ink);
        font-size: 1rem; font-weight: 500; padding: .8rem 3.4rem .8rem 1rem; border-radius: 12px; outline: none; transition: border-color .15s; font-family: inherit;
      }
      .input-eur.sm input { font-size: .94rem; padding: .65rem 2.8rem .65rem .8rem; }
      .input-eur input:focus { border-color: var(--line-strong); }
      .input-eur em { position: absolute; right: 1rem; color: var(--faint); font-style: normal; font-weight: 500; pointer-events: none; font-size: .78rem; letter-spacing: .02em; }

      .text-input { width: 100%; background: rgba(255,255,255,.02); border: 1px solid var(--line); color: var(--ink); font-size: .94rem; padding: .8rem 1rem; border-radius: 12px; outline: none; font-family: ui-monospace, monospace; }
      .text-input:focus { border-color: var(--line-strong); }

      .slider { width: 100%; -webkit-appearance: none; appearance: none; height: 4px; border-radius: 999px; background: rgba(255,255,255,.1); outline: none; }
      .slider::-webkit-slider-thumb { -webkit-appearance: none; width: 17px; height: 17px; border-radius: 50%; background: #fff; cursor: pointer; }
      .slider::-moz-range-thumb { width: 17px; height: 17px; border: none; border-radius: 50%; background: #fff; cursor: pointer; }

      .toggle { display: inline-flex; align-items: center; gap: .55rem; cursor: pointer; }
      .toggle input { display: none; }
      .track { width: 38px; height: 22px; border-radius: 999px; background: rgba(255,255,255,.1); position: relative; transition: background .2s; flex-shrink: 0; }
      .knob { position: absolute; top: 3px; left: 3px; width: 16px; height: 16px; border-radius: 50%; background: #fff; transition: transform .2s; }
      .toggle input:checked + .track { background: rgba(255,255,255,.85); }
      .toggle input:checked + .track .knob { transform: translateX(16px); background: #050505; }
      .toggle-label { font-size: .84rem; color: var(--muted); }

      /* Bouton standard : discret. Le blanc (.primary) est reserve aux actions majeures. */
      .btn { background: #151515; border: 1px solid rgba(255,255,255,.08); color: var(--ink); font-weight: 500; font-size: .85rem; padding: .6rem 1.05rem; border-radius: 10px; cursor: pointer; transition: background .15s, border-color .15s; text-decoration: none; display: inline-flex; align-items: center; gap: .4rem; font-family: inherit; }
      .btn:hover { background: #1c1c1d; border-color: rgba(255,255,255,.14); }
      .btn:disabled { opacity: .35; cursor: not-allowed; }
      .btn.primary { background: #fff; border: none; color: #050505; font-weight: 600; }
      .btn.primary:hover { background: #f0f0f0; }
      .btn.ghost { background: transparent; border-color: var(--line); color: var(--muted); }
      .btn.ghost:hover { background: rgba(255,255,255,.04); color: var(--ink); }
      .btn.danger { background: transparent; border-color: var(--line); color: var(--muted); }
      .btn.danger:hover { background: rgba(255,80,80,.12); border-color: rgba(255,80,80,.25); color: #ff8080; }

      .del { background: rgba(255,255,255,.04); border: none; color: var(--muted); width: 34px; height: 34px; border-radius: 9px; cursor: pointer; font-size: .85rem; flex-shrink: 0; transition: background .15s, color .15s; }
      .del:hover { background: rgba(255,80,80,.15); color: #ff8080; }

      .chip { font-size: .74rem; font-weight: 500; color: var(--muted); background: rgba(255,255,255,.05); padding: .26rem .6rem; border-radius: 999px; }
      .chip.solid { color: #050505; background: rgba(255,255,255,.9); }

      /* Badges de performance : couleur uniquement sur la donnee */
      .badge { font-size: .74rem; font-weight: 600; padding: .26rem .6rem; border-radius: 999px; display: inline-flex; align-items: center; gap: .25rem; }
      .badge.pos { color: var(--green); background: rgba(94,159,115,.12); }
      .badge.neg { color: var(--red); background: rgba(183,107,107,.12); }
      .badge.neutral { color: #cfcfcf; background: rgba(255,255,255,.08); }
      .badge.gold { color: var(--gold); background: rgba(201,168,93,.12); }

      table { width: 100%; border-collapse: collapse; font-size: .88rem; }
      .table-scroll { overflow-x: auto; }
      th { text-align: right; color: var(--muted); font-weight: 500; font-size: .74rem; text-transform: uppercase; letter-spacing: .05em; padding: .5rem .6rem; }
      th:first-child, td:first-child { text-align: left; }
      td { text-align: right; padding: .7rem .6rem; border-bottom: 1px solid var(--line); }
      td.strong, .strong { font-weight: 600; color: var(--ink); }

      .alert { font-size: .82rem; color: var(--muted); margin: .7rem 0 0; }
      .stack { display: flex; flex-direction: column; gap: 1.1rem; }
      .muted-text { color: var(--muted); font-size: .88rem; line-height: 1.6; }
      .muted-text a, a.inline-link { color: var(--ink); text-decoration: underline; text-underline-offset: 2px; }
      .num { font-variant-numeric: tabular-nums; }
    </style>
  </body>
</html>
